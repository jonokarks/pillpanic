{
  "expo": {
    "name": "Pill Panic",
    "slug": "pill-panic",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon-redesign.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon-redesign.png",
      "resizeMode": "contain",
      "backgroundColor": "#101729"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pillpanic.game"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon-redesign.png",
        "backgroundColor": "#101729"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.pillpanic.game"
    },
    "web": {
      "favicon": "./assets/favicon-redesign.png"
    }
  }
}
